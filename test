#!/bin/bash

echo "=== Load namespace from site.json ==="

NAMESPACE=$(jq -r '.namespace' site.json)

if [ -z "$NAMESPACE" ]; then
  echo "ERROR: namespace not found"
  exit 1
fi

echo "Namespace: $NAMESPACE"

export NAMESPACE

echo "=== Deploy with Monaco ==="

monaco deploy manifest.yaml \
  --environment prd \
  --verbose



manifst:

manifestVersion: "1.0"

projects:
  - name: mz
    path: projects/mz

environmentGroups:
  - name: default
    environments:
      - name: prd
        url:
          type: environment
          value: DT_ENVIRONMENT_URL
        auth:
          token:
            type: environment
            value: DT_API_TOKEN


config yaml

configs:
  - id: management-zone
    config:
      name: "mz-${NAMESPACE}"
      template: management-zone.json
    type:
      settings:
        schema: builtin:management-zones

json

