🐚 1. deploy.sh (COMPLET)
#!/bin/bash

echo "=== Dynatrace MZ Deploy START ==="

# 🔐 Variables Dynatrace
export DT_ENVIRONMENT_URL="https://xxxx.live.dynatrace.com"
export DT_API_TOKEN="dt0c01.xxxxxx"

# 🎯 Namespace
export NAMESPACE="packaging-api"

echo "Env URL: $DT_ENVIRONMENT_URL"
echo "Namespace: $NAMESPACE"

# Vérif monaco
if ! command -v monaco &> /dev/null
then
  echo "ERROR: monaco not found"
  exit 1
fi

echo "=== Deploy ==="

monaco deploy manifest.yaml \
  --environment prd \
  --verbose

if [ $? -ne 0 ]; then
  echo "ERROR: Deploy failed"
  exit 1
fi

echo "=== DONE ==="
📄 2. manifest.yaml

👉 ici on lit les variables d’environnement

manifestVersion: "1.0"

projects:
  - name: mz
    path: projects/mz

environmentGroups:
  - name: default
    environments:
      - name: prd
        url:
          type: environment
          value: DT_ENVIRONMENT_URL
        auth:
          token:
            type: environment
            value: DT_API_TOKEN
