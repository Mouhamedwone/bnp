# 🐚 2. Script `run.sh`

👉 version fidèle à ton GitHub Actions + modif N-5

```bash
#!/bin/bash

echo "=== Dynatrace Monaco Export START ==="

# === LOAD ENV ===
export $(grep -v '^#' .env | xargs)

PROJECT_NAME="dynatrace-monaco-export"
OUTPUT_DIR="projects"

# === EXPORT ===
echo "=== Export Dynatrace Configuration ==="

monaco download \
  --manifest manifest.yaml \
  --environment prd \
  --project $PROJECT_NAME \
  --output-folder $OUTPUT_DIR \
  --verbose

if [ $? -ne 0 ]; then
  echo "ERROR: Monaco export failed"
  exit 1
fi

# === PURGE OLD EXPORTS (KEEP 5) ===
cd $OUTPUT_DIR || exit

echo "=== Purge old exports (keep 5) ==="

# --- EXPORT DIRS ---
EXPORT_DIRS=$(ls -d dynatrace-monaco-export_prd_* 2>/dev/null || true)
COUNT_DIRS=$(echo "$EXPORT_DIRS" | grep -v '^$' | wc -l)
NUM_TO_DELETE_DIRS=$((COUNT_DIRS - 5))

if [ $NUM_TO_DELETE_DIRS -gt 0 ]; then
  echo "Found $COUNT_DIRS export directories. Purging $NUM_TO_DELETE_DIRS oldest..."
  echo "$EXPORT_DIRS" | head -n $NUM_TO_DELETE_DIRS | xargs -r rm -rf
else
  echo "No old export directories to purge (found $COUNT_DIRS)"
fi

# --- MANIFEST FILES ---
MANIFEST_FILES=$(ls -1 manifest_*.yaml 2>/dev/null || true)
COUNT_FILES=$(echo "$MANIFEST_FILES" | grep -v '^$' | wc -l)
NUM_TO_DELETE_FILES=$((COUNT_FILES - 5))

if [ $NUM_TO_DELETE_FILES -gt 0 ]; then
  echo "Found $COUNT_FILES manifest backups. Purging $NUM_TO_DELETE_FILES oldest..."
  echo "$MANIFEST_FILES" | head -n $NUM_TO_DELETE_FILES | xargs -r rm -f
else
  echo "No old manifest backups to purge (found $COUNT_FILES)"
fi

echo "=== Dynatrace Monaco Export END ==="
```

